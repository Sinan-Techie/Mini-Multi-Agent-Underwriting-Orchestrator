# ---------------------------
# Security
# ---------------------------
# Secret used for signing JWT tokens. Replace in all environments.
JWT_SECRET=

# ---------------------------
# Service configuration
# ---------------------------
# Orchestrator (FastAPI - /ws/chat)
ORCHESTRATOR_PORT=8000

# Tool service (stateless)
TOOL_SERVICE_PORT=8001
TOOL_SERVICE_URL=http://localhost:8001

# ---------------------------
# State store (single writer: orchestrator)
# ---------------------------
# Supported: sqlite | file | redis
STATE_BACKEND=sqlite

# SQLite
STATE_SQLITE_PATH=./state.db

# File (alternative)
# STATE_BACKEND=file
# STATE_FILE_PATH=./state.json

# Redis (alternative)
# STATE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0

# Session TTL (seconds)
SESSION_TTL_SECONDS=1800

# ---------------------------
# LLM provider
# ---------------------------
# Supported: groq | gemini | openrouter | ollama | openai | anthropic
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenRouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---------------------------
# Embeddings (RAG)
# ---------------------------
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHROMA_PATH=./chroma_data

# ---------------------------
# Observability
# ---------------------------
TRACES_DIR=./traces
# TRACE_LOG_PATH=./traces.log